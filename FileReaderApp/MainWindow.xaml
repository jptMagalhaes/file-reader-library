<Window x:Class="FileReaderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="File Reader Library — Interactive Demo"
        Height="640" Width="900"
        MinHeight="480" MinWidth="560"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Cascadia Mono, Consolas">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" CornerRadius="16" GlassFrameThickness="0" ResizeBorderThickness="6" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="Cream" Color="#F3ECDD" />
        <SolidColorBrush x:Key="Teal" Color="#8FD3C7" />
        <SolidColorBrush x:Key="Ink" Color="#1A1A1A" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Cream}" />
            <Setter Property="Foreground" Value="{StaticResource Ink}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Face" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Ink}" BorderThickness="2" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Face" Property="Background" Value="{StaticResource Teal}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="{StaticResource Cream}" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{StaticResource Ink}"
                                BorderThickness="2" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Teal}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{StaticResource Ink}"
                                BorderThickness="2" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Ink}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="18" Height="18" VerticalAlignment="Center" CornerRadius="4"
                                    BorderBrush="{StaticResource Ink}" BorderThickness="2"
                                    Background="{StaticResource Cream}">
                                <Border x:Name="Fill" Margin="2" CornerRadius="2" Background="{StaticResource Teal}"
                                        Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Fill" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Cream}" CornerRadius="16" BorderBrush="{StaticResource Ink}"
            BorderThickness="2" Margin="10">
        <DockPanel>
            <Grid DockPanel.Dock="Top" Height="36" Margin="16,0">
                <TextBlock VerticalAlignment="Center" FontWeight="Bold" Text="▣ File Reader Library" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleBarButton}" Content="–" Margin="0,0,8,0"
                            Click="OnMinimizeClick" />
                    <Button Style="{StaticResource TitleBarButton}" Content="×" Click="OnCloseClick" />
                </StackPanel>
            </Grid>

            <Grid Margin="24,8,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="112" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                           FontStyle="Italic" Foreground="#6B6355"
                           Text="read files. no drama." />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Sample" />
                <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" LastChildFill="True">
                    <Button DockPanel.Dock="Right" Margin="8,0,0,0" MinWidth="96"
                            Command="{Binding BrowseCommand}" Content="Browse..." />
                    <ComboBox ItemsSource="{Binding SampleFiles}"
                              SelectedItem="{Binding SelectedSampleFile}" />
                </DockPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="File path" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True"
                         Text="{Binding SelectedFilePath, Mode=OneWay, FallbackValue=''}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Format" />
                <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,8"
                          ItemsSource="{Binding AvailableFormats}"
                          SelectedItem="{Binding SelectedFormat}" />

                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" Orientation="Horizontal">
                    <CheckBox Margin="0,0,16,0" Content="File is encrypted" IsChecked="{Binding UseEncryption}" />
                    <CheckBox Content="Role security" IsChecked="{Binding UseRoleSecurity}" />
                </StackPanel>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Text="Role" />
                <ComboBox Grid.Row="5" Grid.Column="1" Margin="0,0,0,8"
                          IsEnabled="{Binding IsRoleSelectionEnabled}"
                          ItemsSource="{Binding AvailableRoles}"
                          SelectedItem="{Binding SelectedRole}" />

                <Button Grid.Row="6" Grid.Column="1" Margin="0,0,0,12" HorizontalAlignment="Left"
                        MinWidth="96" Command="{Binding ReadCommand}" Content="Read" />

                <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Background="White"
                        BorderBrush="{StaticResource Ink}" BorderThickness="2" CornerRadius="8">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <TextBox IsReadOnly="True" Text="{Binding Output, Mode=OneWay}"
                                 TextWrapping="Wrap" FontFamily="Cascadia Mono, Consolas" FontSize="14"
                                 BorderThickness="0" Background="Transparent" Margin="8" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
